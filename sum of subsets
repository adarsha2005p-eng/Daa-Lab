#include <stdio.h>

int w[20], x[20], n, target;

// Function to print subset
void printSubset() {
    printf("{ ");
    for(int i = 0; i < n; i++) {
        if(x[i] == 1)
            printf("%d ", w[i]);
    }
    printf("}\n");
}

// Sum of subsets using backtracking
void sumOfSubsets(int s, int k, int r) {
    x[k] = 1;

    if(s + w[k] == target) {
        printSubset();
    }
    else if(s + w[k] + w[k+1] <= target) {
        sumOfSubsets(s + w[k], k + 1, r - w[k]);
    }

    if((s + r - w[k] >= target) && (s + w[k+1] <= target)) {
        x[k] = 0;
        sumOfSubsets(s, k + 1, r - w[k]);
    }
}

int main() {
    int total = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements in increasing order:\n");
    for(int i = 0; i < n; i++) {
        scanf("%d", &w[i]);
        total += w[i];
    }

    printf("Enter target sum: ");
    scanf("%d", &target);

    if(total < target) {
        printf("No solution possible\n");
        return 0;
    }

    sumOfSubsets(0, 0, total);

    return 0;
}
