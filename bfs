#include <stdio.h>

#define MAX 10

int graph[MAX][MAX], visited[MAX], queue[MAX], n;

// BFS function
void bfs(int start) {
    int front = 0, rear = 0;

    queue[rear++] = start;
    visited[start] = 1;

    while(front < rear) {
        int node = queue[front++];
        printf("%d ", node);

        for(int i = 0; i < n; i++) {
            if(graph[node][i] == 1 && visited[i] == 0) {
                queue[rear++] = i;
                visited[i] = 1;
            }
        }
    }
}

int main() {
    int i, j;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }

    // Initialize visited array
    for(i = 0; i < n; i++)
        visited[i] = 0;

    printf("BFS Traversal: ");
    bfs(0);   // start from node 0

    return 0;
}
