#include <stdio.h>

#define MAX 10

int graph[MAX][MAX], visited[MAX], n;

// DFS function
void dfs(int node) {
    printf("%d ", node);
    visited[node] = 1;

    for(int i = 0; i < n; i++) {
        if(graph[node][i] == 1 && visited[i] == 0) {
            dfs(i);
        }
    }
}

int main() {
    int i, j;

    printf("Enter number of nodes: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }

    // Initialize visited array
    for(i = 0; i < n; i++)
        visited[i] = 0;

    printf("DFS Traversal: ");
    dfs(0);   // start from node 0

    return 0;
}
